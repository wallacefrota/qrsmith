{
  "name": "qrsmith",
  "version": "1.0.1",
  "description": "Beautiful QR codes in your terminal — compact, colorful, and versatile",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
  ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.js"
      }
    }
  }
  "bin": {
    "qrsmith": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "qr",
    "qrcode",
    "terminal",
    "cli",
    "unicode",
    "braille",
    "svg",
    "console",
    "ansi"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Wallace Frota",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "qrcode-generator": "^2.0.4"
  }
}
